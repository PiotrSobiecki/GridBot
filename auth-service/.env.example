# === WYMAGANE ===

# Sekret JWT do podpisywania tokenów autoryzacyjnych (min. 32 znaki)
JWT_SECRET=

# Klucz szyfrowania kluczy API użytkowników w bazie (64 hex = 32 bajty)
# Wygeneruj: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_ENCRYPTION_KEY=

# === GIEŁDA (globalne klucze do pobierania cen) ===

# Klucze API BingX – używane TYLKO do pobierania cen (ticker/24hr)
# Nie są fallbackiem dla użytkowników – każdy user podaje własne klucze do handlu
API_KEY_BINGX=
API_KEY_SECRET_BINGX=

# === OPCJONALNE ===

# Interwał schedulera GRID w sekundach (domyślnie: 30)
GRID_SCHEDULER_INTERVAL_SEC=30

# Tryb symulacji – paper trading bez prawdziwych transakcji (domyślnie: false)
SIMULATION_MODE=false

# Włącz szczegółowe logi warunków kupna/sprzedaży (0 lub 1, domyślnie: 0)
GRID_DEBUG_CONDITIONS=0

# === BAZA DANYCH ===

# URL PostgreSQL (jeśli nie ustawione – używany SQLite z pliku data/gridbot.db)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Wyłącz weryfikację SSL dla PostgreSQL (self-signed certs, np. Railway)
# PG_SSL_INSECURE=true
